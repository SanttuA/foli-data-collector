# For a local development database, this file URL is enough.
# For Turso, replace it with the value from `turso db show --url <db-name>`.
TURSO_DATABASE_URL=file:data/foli.db

# Required for remote Turso/libSQL URLs. Leave empty for local file:data/foli.db.
TURSO_AUTH_TOKEN=

# Føli recommends identifiable User-Agent values.
FOLI_USER_AGENT=foli-data-collector/0.1.0 (+https://github.com/your-name/foli-data-collector; no-public)
FOLI_BASE_URL=http://data.foli.fi

POLL_VM_SECONDS=30
POLL_ALERTS_SECONDS=300
GTFS_ARCHIVE_INTERVAL_HOURS=168
DATA_DIR=./data
HEALTHCHECK_VM_MAX_AGE_SECONDS=300

